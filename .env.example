# ============================================================
# Telegram Bot - Environment Variables Template
# ============================================================
# Copy the values below into:
#   - Vercel Dashboard → Settings → Environment Variables
#   - OR Replit → Secrets tab
# Do NOT rename this file to .env and commit it with real values!
# ============================================================

# From https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP
TELEGRAM_BOT_TOKEN_2=9876543210:ZZYYxxWWvvUUttSSrrQQppOOnnMM

# List of Telegram user IDs who are admins (JSON array format)
ADMINS=[123456789]

# Max number of requests per user per minute before spam protection kicks in
LIMIT_SPAM=20

# Telegram user ID to notify about payments/donations
ADMIN_TO_UPDATE_OF_PAYMENT=123456789
